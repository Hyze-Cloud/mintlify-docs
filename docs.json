{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Hyze Cloud",
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "colors": {
    "primary": "#6d5dd3",
    "light": "#6d5dd3",
    "dark": "#6d5dd3"
  },
  "api": {
    "openapi": {
      "source": "openapi.json",
      "directory": "api-reference"
    },
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript", "go"],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    },
    "mdx": {
      "auth": {
        "method": "bearer"
      },
      "server": "https://api.hyze.cloud/api"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Start",
            "pages": ["index", "quickstart", "getting-started/authentication"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Endpoints",
            "openapi": "openapi.json"
          }
        ]
      },
      {
        "tab": "FAQ",
        "groups": [
          {
            "group": "Help",
            "pages": ["faq"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.hyze.cloud",
          "icon": "rocket"
        },
        {
          "anchor": "API Status",
          "href": "https://api.hyze.cloud/health",
          "icon": "signal"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/hyzecloud/hyzecloud",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "llms.txt",
        "href": "/llms.txt"
      },
      {
        "label": "Repositório",
        "href": "https://github.com/hyzecloud/hyzecloud"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.hyze.cloud"
    }
  },
  "fonts": {
    "family": "Fustat"
  },
  "styling": {
    "latex": true,
    "codeblocks": "system"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/hyzecloud",
      "github": "https://github.com/hyzecloud",
      "linkedin": "https://linkedin.com/company/hyzecloud"
    }
  }
}
