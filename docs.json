{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Hyze Cloud",
  "description": "Documentação oficial da Hyze Cloud: deploy de apps Node, Bun e Python, bancos gerenciados, API REST, rate limits, secrets e automação.",
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "colors": {
    "primary": "#7c46ce",
    "light": "#8b5cf6",
    "dark": "#7c46ce"
  },
  "api": {
    "openapi": {
      "source": "openapi.json",
      "directory": "api-reference"
    },
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript", "go"],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    },
    "mdx": {
      "auth": {
        "method": "bearer"
      },
      "server": "https://api.hyzecloud.com/api"
    }
  },
  "favicon": {
    "light": "/logo/logo2-light.png",
    "dark": "/logo/logo2.png"
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "robots": "index, follow",
      "googlebot": "index, follow",
      "canonical": "https://docs.hyzecloud.app",
      "og:url": "https://docs.hyzecloud.app",
      "og:site_name": "Hyze Cloud Docs",
      "og:type": "website",
      "og:locale": "pt_BR",
      "og:locale:alternate": "en_US",
      "twitter:card": "summary_large_image",
      "twitter:site": "@hyzecloud",
      "twitter:creator": "@hyzecloud",
      "theme-color": "#7c46ce",
      "application-name": "Hyze Cloud Docs",
      "apple-mobile-web-app-title": "Hyze Docs",
      "author": "Hyze Cloud",
      "keywords": "Hyze Cloud, documentação, API, deploy, Node.js, Bun, Python, PostgreSQL, hosting, PaaS, rate limit, apps, databases, docs.hyzecloud.app",
      "category": "Technology"
    },
    "organization": {
      "id": "https://docs.hyzecloud.app/#organization",
      "name": "Hyze Cloud",
      "url": "https://hyzecloud.app",
      "logo": "https://docs.hyzecloud.app/logo/logo2.png",
      "sameAs": [
        "https://x.com/hyzecloud",
        "https://github.com/hyze-cloud",
        "https://linkedin.com/company/hyzecloud"
      ]
    }
  },
  "search": {
    "prompt": "Buscar na documentação…"
  },
  "metadata": {
    "timestamp": true
  },
  "thumbnails": {
    "background": "/images/hero-background.png"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "http://hyzecloud.com/dashboard",
          "icon": "rocket"
        },
        {
          "anchor": "Status",
          "href": "https://status.hyzecloud.com/",
          "icon": "signal"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/hyze-cloud",
          "icon": "github"
        }
      ]
    },
    "languages": [
      {
        "language": "en",
        "tabs": [
          {
            "tab": "Getting Started",
            "groups": [
              {
                "group": "Get started",
                "pages": [
                  "en/index",
                  "en/quickstart",
                  "en/getting-started/authentication"
                ]
              }
            ]
          },
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "How-to",
                "pages": [
                  "en/guides/deploy-an-app",
                  "en/guides/deploy-from-github",
                  "en/guides/provision-a-database",
                  "en/guides/back-up-a-database",
                  "en/guides/manage-secrets",
                  "en/guides/view-logs"
                ]
              },
              {
                "group": "Examples",
                "pages": [
                  "en/examples/deploy-with-curl",
                  "en/examples/app-with-database"
                ]
              }
            ]
          },
          {
            "tab": "Concepts",
            "groups": [
              {
                "group": "Platform",
                "pages": [
                  "en/concepts/apps",
                  "en/concepts/databases",
                  "en/concepts/workspaces",
                  "en/concepts/secrets-and-env",
                  "en/concepts/rate-limits"
                ]
              }
            ]
          },
          {
            "tab": "SDKs",
            "groups": [
              {
                "group": "Clients",
                "pages": [
                  "en/sdks/overview",
                  "en/sdks/typescript"
                ]
              }
            ]
          },
          {
            "tab": "API Reference",
            "groups": [
              {
                "group": "Overview",
                "pages": ["api-reference/introduction"]
              },
              {
                "group": "Endpoints",
                "openapi": "openapi.json"
              }
            ]
          },
          {
            "tab": "FAQ",
            "groups": [
              {
                "group": "Help",
                "pages": ["en/faq"]
              }
            ]
          }
        ],
        "navbar": {
          "links": [],
